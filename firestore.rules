rules_version = '2';

// NWSA Music Hub — Firestore security rules
//
// Two tiers of data:
//   • PUBLIC collections are world-readable (they power the public site:
//     schedules, ensemble rosters, repertoire, announcements). They contain
//     no private contact info. Only staff (Owner/Director) may write them.
//   • PRIVATE collections (contact details, attendance exceptions, progress
//     notes, private lessons) are readable and writable only by signed-in
//     staff — never world-readable.
//
// Four access levels (#roles), stored on each directors/{email} doc's
// `role` field:
//   • owner     — exactly one account. The only one that can add/remove a
//                 director or change anyone's role.
//   • director  — full edit access to everything except the Directors list.
//   • teacher   — scoped to scheduling their OWN private lessons (see
//                 `lessons` and the `kind == 'lesson'` exception on
//                 `rosterOverrides` below). Can't touch rosters, schedule,
//                 repertoire, documents, announcements, contacts, or the
//                 Directors list.
//   • assistant — Personnel Assistant: reads/writes ATTENDANCE only, and only
//                 for the ensembles named in their doc's `assignedEnsembleIds`
//                 (plus the narrow side-effects of taking roll: the event's
//                 rollTaken receipt, lesson pull-out overrides, and reading
//                 planned absences). Never contacts, notes, grades, or any
//                 public-collection write.
// A doc with no `role` predates this feature and is treated as a full
// director (see isStaff()) — nobody with existing access loses it.
//
// The AI enrichment GitHub Action authenticates with a service account via the
// Admin SDK, which bypasses these rules entirely — so enrichment writes work
// regardless of what's below.
//
// Deploy with:  firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function myDirectorDoc() {
      return get(/databases/$(database)/documents/directors/$(request.auth.token.email)).data;
    }

    // A director is an authenticated user who has a doc in the `directors`
    // collection (doc id = their lowercased Google sign-in email). Google
    // sign-in lets ANY Google account authenticate, so checking only
    // `request.auth != null` would expose student contact info, attendance,
    // and progress notes to anyone who finds the URL.
    //
    // The allowlist lives in DATA (see the `directors` match block below), not
    // in this file — so a director is added or removed from inside the app with
    // NO rules redeploy. That closes the old trap where the app's sign-in mirror
    // shipped automatically but this file had to be deployed by hand, leaving a
    // newly-added director able to open the app but unable to save.
    function signedIn() {
      return request.auth != null
        && exists(/databases/$(database)/documents/directors/$(request.auth.token.email));
    }

    // The Owner: the one account allowed to manage the Directors list itself.
    function isOwner() {
      return signedIn() && myDirectorDoc().role == 'owner';
    }

    function isTeacherRole() {
      return signedIn() && myDirectorDoc().role == 'teacher';
    }

    // Personnel Assistant (#roles): attendance-only, for assigned ensembles.
    function isAssistantRole() {
      return signedIn() && myDirectorDoc().role == 'assistant';
    }

    // Is `ensembleId` one of the signed-in assistant's assigned ensembles?
    function assistantCovers(ensembleId) {
      return isAssistantRole()
        && ensembleId in myDirectorDoc().get('assignedEnsembleIds', []);
    }

    // Full director privileges: Owner, Director, or a legacy doc with no
    // role set (every director created before roles existed). Explicit
    // 'teacher' and 'assistant' roles are excluded.
    function isStaff() {
      return signedIn() && !isTeacherRole() && !isAssistantRole();
    }

    // ── Public read · staff write ────────────────────
    match /ensembles/{doc}       { allow read; allow write: if isStaff(); }
    match /students/{doc}        { allow read; allow write: if isStaff(); }
    // events: staff edit freely. A Personnel Assistant may update ONLY the
    // rollTaken receipt (the side-effect of finishing roll) — never the
    // schedule itself — and only the receipt entries for THEIR ensembles.
    match /events/{doc} {
      allow read;
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || (isAssistantRole()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rollTaken'])
            && request.resource.data.rollTaken
                 .diff(resource.data.get('rollTaken', {}))
                 .affectedKeys()
                 .hasOnly(myDirectorDoc().get('assignedEnsembleIds', [])));
    }
    // rosterOverrides: staff can write anything. A Teacher may create/edit/
    // delete only THEIR OWN private-lesson pull-outs (kind == 'lesson') — the
    // automatic side effect of scheduling a lesson that conflicts with a
    // rehearsal/class (see the `lessons` collection below). Teachers never
    // touch ordinary subs/pull-outs or another teacher's lesson entries.
    // A Personnel Assistant gets the same lesson-only exception (the Lesson
    // button on Take Roll records a pull-out window) — scoped to the
    // ensembles they cover.
    match /rosterOverrides/{doc} {
      allow read;
      allow create: if isStaff()
        || (isTeacherRole() && request.resource.data.kind == 'lesson')
        || (request.resource.data.kind == 'lesson' && assistantCovers(request.resource.data.ensembleId));
      allow update: if isStaff()
        || (isTeacherRole() && resource.data.kind == 'lesson' && request.resource.data.kind == 'lesson')
        || (resource.data.kind == 'lesson' && request.resource.data.kind == 'lesson'
            && assistantCovers(resource.data.ensembleId)
            && request.resource.data.ensembleId == resource.data.ensembleId);
      allow delete: if isStaff()
        || (isTeacherRole() && resource.data.kind == 'lesson')
        || (resource.data.kind == 'lesson' && assistantCovers(resource.data.ensembleId));
    }
    match /announcements/{doc}   { allow read; allow write: if isStaff(); }
    match /repertoire/{doc}      { allow read; allow write: if isStaff(); }
    // Assignment DEFINITIONS (title, type, due date, target) are public so
    // students see what's assigned. Individual RESULTS/grades stay private below.
    match /assignments/{doc}     { allow read; allow write: if isStaff(); }
    match /seatingCharts/{doc}   { allow read; allow write: if isStaff(); }
    match /locations/{doc}       { allow read; allow write: if isStaff(); }
    // Document repository (syllabi, handbooks, forms). Metadata is public so the
    // Documents page and per-ensemble lists can render; the files themselves
    // live in Storage. Only staff may add/edit/remove entries.
    match /documents/{doc}       { allow read; allow write: if isStaff(); }

    // Planned absences (#27): anyone may SUBMIT one (create-only, shape-checked),
    // but only staff can read the queue or change/delete entries — so the
    // public side can't enumerate or tamper with other students' reports.
    match /plannedAbsences/{doc} {
      allow create: if request.resource.data.keys().hasOnly(['studentId', 'studentName', 'date', 'reason', 'submittedAt', 'status'])
        && request.resource.data.studentId is string
        && request.resource.data.date is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 300
        && request.resource.data.status == 'pending';
      // Assistants read the queue too — Take Roll shows "reported ahead"
      // chips so they can accept a planned absence as Excused.
      allow read: if isStaff() || isAssistantRole();
      allow update, delete: if isStaff();
    }

    // Outbound notification queue (#21): staff-only writes; Power Automate
    // reads it with a service credential (Admin SDK bypasses rules).
    match /notifyQueue/{doc}     { allow read, write: if isStaff(); }

    // Private lessons (#roles): a Teacher schedules/edits/cancels their OWN
    // lessons; Owner/Director can see and manage all of them (coordination —
    // e.g. confirming a conflict with the ensemble director). Never world-
    // readable, since it names an individual student and their teacher.
    match /lessons/{doc} {
      // Not plain signedIn(): a Personnel Assistant is attendance-only and
      // has no business reading who takes private lessons with whom.
      allow read: if isStaff() || isTeacherRole();
      allow create: if isStaff() || (isTeacherRole() && request.resource.data.teacherEmail == request.auth.token.email);
      allow update, delete: if isStaff() || (isTeacherRole() && resource.data.teacherEmail == request.auth.token.email);
    }

    // ── Private · staff read + write only ──────────────
    match /contacts/{doc}           { allow read, write: if isStaff(); }
    // attendance: staff freely; a Personnel Assistant reads all (roll needs
    // same-day context across periods) but writes only records for THEIR
    // assigned ensembles.
    match /attendance/{doc} {
      allow read: if isStaff() || isAssistantRole();
      allow create: if isStaff() || assistantCovers(request.resource.data.ensembleId);
      // Update: the record must belong to a covered ensemble AND stay there —
      // an assistant can't re-home a record into an ensemble they don't cover.
      allow update: if isStaff()
        || (assistantCovers(resource.data.ensembleId)
            && request.resource.data.ensembleId == resource.data.ensembleId);
      allow delete: if isStaff() || assistantCovers(resource.data.ensembleId);
    }
    match /progressNotes/{doc}      { allow read, write: if isStaff(); }
    match /assignmentResults/{doc}  { allow read, write: if isStaff(); }

    // ── Director allowlist (stored as data) ─────────────
    // Owner-only management (#roles): only the Owner may add/remove a
    // director, change a role, or even list the roster — closes the gap
    // where any signed-in director could see or edit who has access. Two
    // narrow self-service exceptions keep the app usable day-to-day:
    //   • a signed-in user may always GET their own doc (to discover
    //     whether they're a director — the app gates access on this);
    //   • a director may UPDATE only `name` and/or `assignedStudentIds` on
    //     their OWN doc — auto-captured display name on first sign-in, and a
    //     Teacher adjusting their own "students assigned to me" list.
    match /directors/{email} {
      allow get:  if request.auth != null
                     && (request.auth.token.email == email || isOwner());
      allow list: if isOwner();
      // Existing directors are seeded out-of-band (Admin SDK bypasses these
      // rules); from here on, only the Owner adds or edits others.
      allow create: if isOwner();
      allow update: if isOwner()
        || (request.auth != null && request.auth.token.email == email
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'assignedStudentIds']));
      // The Owner may remove any OTHER director, but never their own
      // account — the app can never end up ownerless.
      allow delete: if isOwner() && request.auth.token.email != email;
    }

    // ── Deny everything else by default ─────────────────
    match /{document=**}         { allow read, write: if false; }
  }
}
