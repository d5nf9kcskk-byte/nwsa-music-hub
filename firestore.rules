rules_version = '2';

// NWSA Music Hub — Firestore security rules
//
// Two tiers of data:
//   • PUBLIC collections are world-readable (they power the public site:
//     schedules, ensemble rosters, repertoire, announcements). They contain
//     no private contact info. Only a signed-in director may write them.
//   • PRIVATE collections (contact details, attendance exceptions, progress
//     notes) are readable and writable only by a signed-in director.
//
// The AI enrichment GitHub Action authenticates with a service account via the
// Admin SDK, which bypasses these rules entirely — so enrichment writes work
// regardless of what's below.
//
// Deploy with:  firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // A director is an authenticated user whose Google email is on the allowlist
    // below. Google sign-in lets ANY Google account authenticate, so checking
    // only `request.auth != null` would expose student contact info, attendance,
    // and progress notes to anyone who finds the URL. Add each director's exact
    // Google sign-in email here, then deploy:  firebase deploy --only firestore:rules
    function signedIn() {
      return request.auth != null
        && request.auth.token.email in [
          'ggmuze@yahoo.com'
          // add more director emails here, comma-separated
        ];
    }

    // ── Public read · director write ────────────────────────────
    match /ensembles/{doc}       { allow read; allow write: if signedIn(); }
    match /students/{doc}        { allow read; allow write: if signedIn(); }
    match /events/{doc}          { allow read; allow write: if signedIn(); }
    match /rosterOverrides/{doc} { allow read; allow write: if signedIn(); }
    match /announcements/{doc}   { allow read; allow write: if signedIn(); }
    match /repertoire/{doc}      { allow read; allow write: if signedIn(); }
    // Assignment DEFINITIONS (title, type, due date, target) are public so
    // students see what's assigned. Individual RESULTS/grades stay private below.
    match /assignments/{doc}     { allow read; allow write: if signedIn(); }
    match /seatingCharts/{doc}   { allow read; allow write: if signedIn(); }

    // ── Private · director read + write only ──────────────
    match /contacts/{doc}           { allow read, write: if signedIn(); }
    match /attendance/{doc}         { allow read, write: if signedIn(); }
    match /progressNotes/{doc}      { allow read, write: if signedIn(); }
    match /assignmentResults/{doc}  { allow read, write: if signedIn(); }

    // ── Deny everything else by default ─────────────────
    match /{document=**}         { allow read, write: if false; }
  }
}
